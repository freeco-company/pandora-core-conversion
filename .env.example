# Application
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://pandora:pandora@localhost:5432/pandora_conversion

# Pandora Core Identity Service (JWT issuer)
PANDORA_CORE_BASE_URL=http://localhost:8001
PANDORA_CORE_ISSUER=https://id.js-store.com.tw
PANDORA_CORE_PUBLIC_KEY_TTL=3600
# Comma-separated product_code whitelist
PANDORA_CORE_ALLOWED_PRODUCTS=pandora_js_store,doudou,fairy_calendar,fairy_skin,fairy_academy

# Internal service-to-service shared secret (for non-user webhook callers)
INTERNAL_SHARED_SECRET=change-me
